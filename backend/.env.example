# GEMINI_API_KEY / MISTRAL_API_KEY: no longer used for PDF/OCR extraction
# (that now runs locally via Tesseract — see services/tesseract_ocr_service.py).
# GEMINI_API_KEY is kept here only because config.py still requires it as a
# non-optional field (services/gemini_service.py and services/mistral_service.py
# are unused dead code at this point, not wired into main.py).
# OCR itself has NO env var / API key requirement — it needs the `tesseract-ocr`
# and `tesseract-ocr-por` system packages installed (see Dockerfile).
GEMINI_API_KEY=your_gemini_api_key_here
MISTRAL_API_KEY=your_mistral_api_key_here
# Only set this if `tesseract --version` fails in your terminal even though
# Tesseract is installed (i.e. it's not on PATH). Point it at the actual
# tesseract.exe, e.g. on Windows:
# TESSERACT_CMD=C:\Program Files\Tesseract-OCR\tesseract.exe
TESSERACT_CMD=
ENVIRONMENT=development
MAX_FILE_SIZE_MB=50
CORS_ORIGINS=["http://localhost:3000"]
LOG_LEVEL=INFO
